rules_version='2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email in ['kojusun@gmail.com'];
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if true;
      allow create: if hasOnlyKeys(
        request.resource.data,
        [
          'userId', 'password', 'name', 'phone', 'gender', 'legalConsent',
          'createdAt', 'lastLoginAt', 'notificationSettings',
          'notificationSettingsUpdatedAt', 'profileImageUrl', 'photoURL',
          'avatarUrl', 'image', 'updatedAt', 'authUid', 'authEmail', 'authRole'
        ]
      ) && isAuthenticated();
      allow update: if hasOnlyKeys(
        request.resource.data,
        [
          'userId', 'password', 'name', 'phone', 'gender', 'legalConsent',
          'createdAt', 'lastLoginAt', 'notificationSettings',
          'notificationSettingsUpdatedAt', 'profileImageUrl', 'photoURL',
          'avatarUrl', 'image', 'updatedAt', 'authUid', 'authEmail', 'authRole'
        ]
      ) && isAuthenticated();
      allow delete: if false;

      match /fcm_tokens/{tokenId} {
        allow read: if true;
        allow create, update: if hasOnlyKeys(
          request.resource.data,
          ['token', 'enabled', 'platform', 'updatedAt']
        ) && isAuthenticated();
        allow delete: if false;
      }
    }

    match /partners/{partnerId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();

      match /fcm_tokens/{tokenId} {
        allow read: if true;
        allow create, update: if hasOnlyKeys(
          request.resource.data,
          ['token', 'enabled', 'platform', 'updatedAt']
        ) && isAuthenticated();
        allow delete: if false;
      }
    }

    match /chat_threads/{threadId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /chat_messages/{messageId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /user_notifications/{notificationId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /partner_reviews/{reviewId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /subscription_requests/{requestId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /cs_tickets/{ticketId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isSignedInAdmin();
    }

    match /partner_profile_views/{viewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isSignedInAdmin();
    }

    match /call_click_logs/{logId} {
      allow read: if isSignedInAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isSignedInAdmin();
    }

    // 앱 필터는 사용자 읽기 허용, 수정은 관리자만 허용
    match /app_filters/{docId} {
      allow read: if true;
      allow create, update, delete: if isSignedInAdmin();
    }

    // 앱 메인 넓은 배너(간판): 소비자 앱은 읽기, 관리자만 편집
    match /app_main_billboard/{docId} {
      allow read: if true;
      allow create, update, delete: if isSignedInAdmin();
    }

    // 운영/관리자 영역은 관리자 계정만 접근
    match /admin_configs/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /admin_messages/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /admin_audit_logs/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /admin_sidebar_badge_reads/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /categories/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /subscription_logs/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /penalties/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /notifications/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /system_notification_dedupe/{docId} {
      allow read, write: if isSignedInAdmin();
    }
    match /reviews/{docId} {
      allow read, write: if isSignedInAdmin();
    }

    // 명시되지 않은 컬렉션은 기본 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
